# ============================================================
# Papi Chulo v2 — VL Real Estate Digital Employee
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env — it contains real credentials
# ============================================================

# --- General ---
BOT_NAME="Papi Chulo"

# --- Hostfully API ---
HOSTFULLY_API_KEY=""
HOSTFULLY_AGENCY_UID=""
HOSTFULLY_API_URL="https://api.hostfully.com/api/v3.2"

# --- Claude API Access ---
# Mode: "proxy" uses claude-max-api (Claude Max subscription, $0 extra)
#       "api"   uses Anthropic API key (pay-per-token)
CLAUDE_MODE="proxy"
# If CLAUDE_MODE=proxy: start with `claude-max-api`, defaults to port 3456
CLAUDE_PROXY_URL="http://127.0.0.1:3456"
CLAUDE_MODEL="claude-sonnet-4-20250514"
# If CLAUDE_MODE=api:
# ANTHROPIC_API_KEY=""

# --- Claude Resilience (optional) ---
# Retry attempts on transient connection failures (default: 2)
# CLAUDE_RETRY_ATTEMPTS="3"
# Per-request timeout in milliseconds (default: 30000)
# CLAUDE_TIMEOUT_MS="30000"
# Fall back to Anthropic API if proxy is unreachable (requires ANTHROPIC_API_KEY)
# CLAUDE_FALLBACK_TO_API="true"

# --- Slack (fill in after Task 9 — Slack App creation) ---
SLACK_BOT_TOKEN=""
SLACK_APP_TOKEN=""
SLACK_CHANNEL_ID=""

# --- Webhook Server ---
WEBHOOK_PORT=48901

# --- Tailscale ---
WEBHOOK_PUBLIC_URL=""

# --- OpenClaw ---
OPENCLAW_HOOKS_TOKEN=""   # 64-char hex, generated during security hardening

# ==============================================================
# NOTION INTEGRATION (optional)
# ==============================================================
# Internal integration token from https://www.notion.so/profile/integrations
# Leave empty to disable the Notion wiki knowledge source.
# NOTION_TOKEN=secret_your_notion_token_here

# Optional: override defaults
# NOTION_DB_PATH=data/notion-embeddings.db
# NOTION_SYNC_INTERVAL_HOURS=1
# NOTION_MAX_CONTEXT_CHARS=2000
# NOTION_TOP_K=5
