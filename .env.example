# ============================================================
# Papi Chulo v2 — VL Real Estate Digital Employee
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env — it contains real credentials
# ============================================================

# --- General ---
BOT_NAME="Papi Chulo"

# --- Hostfully API ---
HOSTFULLY_API_KEY=""
HOSTFULLY_AGENCY_UID=""
HOSTFULLY_API_URL="https://api.hostfully.com/api/v3.2"

# --- AI (OpenRouter) ---
# Get your API key at https://openrouter.ai/keys
# Format: sk-or-... (starts with "sk-or-")
# The service validates this key at startup and exits if invalid.
# To rotate: generate a new key at openrouter.ai/keys, update here, restart.
# Model ID in OpenRouter format, e.g. "minimax/minimax-m2.7" or "anthropic/claude-sonnet-4-20250514"
OPENROUTER_MODEL="minimax/minimax-m2.7"
OPENROUTER_API_KEY=""

# --- AI Resilience (optional) ---
# Retry attempts on transient connection failures (default: 2)
# OPENROUTER_RETRY_ATTEMPTS="3"
# Per-request timeout in milliseconds (default: 30000)
# OPENROUTER_TIMEOUT_MS="30000"

# --- Slack (fill in after Task 9 — Slack App creation) ---
SLACK_BOT_TOKEN=""
SLACK_APP_TOKEN=""
SLACK_CHANNEL_ID=""

# --- Webhook Server ---
WEBHOOK_PORT=48901

# --- Tailscale ---
WEBHOOK_PUBLIC_URL=""

# --- OpenClaw ---
OPENCLAW_HOOKS_TOKEN=""   # 64-char hex, generated during security hardening

# ==============================================================
# NOTION INTEGRATION (optional)
# ==============================================================
# Internal integration token from https://www.notion.so/profile/integrations
# Leave empty to disable the Notion wiki knowledge source.
# NOTION_TOKEN=secret_your_notion_token_here

# Optional: override defaults
# NOTION_DB_PATH=data/notion-embeddings.db
# NOTION_SYNC_INTERVAL_HOURS=1
# NOTION_MAX_CONTEXT_CHARS=2000
# NOTION_TOP_K=5

# ==============================================================
# SIFELY SMART LOCK API
# ==============================================================
SIFELY_BASE_URL="https://app-smart-server.sifely.com"
SIFELY_CLIENT_ID=""
SIFELY_USERNAME=""
SIFELY_PASSWORD=""   # MD5 hash of your Sifely account password

# ==============================================================
# VLRE-HUB INTERNAL API
# ==============================================================
VLRE_HUB_URL="http://localhost:7311"   # Tailscale internal address of vlre-hub
